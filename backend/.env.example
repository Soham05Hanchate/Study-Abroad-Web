# AI provider
GROQ_API_KEY=your_groq_api_key

# MongoDB Atlas (optional; server runs without it, but lead persistence will be disabled)
# Example: mongodb+srv://username:password@cluster.mongodb.net/databaseName?retryWrites=true&w=majority
MONGODB_URI=

# Optional: exit if URI is set but connection fails
REQUIRE_MONGODB=false

# Optional: protect admin routes
ADMIN_API_KEY=

# Comma-separated allowed origins for browser requests in production
# Example: https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=

# Server port
PORT=5000
